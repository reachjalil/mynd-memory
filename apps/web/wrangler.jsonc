{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "mynd-memory",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "compatibility_date": "2026-06-21",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "routes": [
    {
      "pattern": "myndmemory.com",
      "custom_domain": true
    }
  ],
  "vars": {
    "HYDRA_TENANT_ID": "myndmemory_demo",
    "HYDRA_SHARED_SUB_TENANT_ID": "demo_shared",
    "MYND_MEMORY_DEMO_USER_ID": "demo_user",
    "MYND_MEMORY_INFERENCE_PROVIDER": "nebius",
    "MYND_MEMORY_GATEWAY_MODEL": "openai/gpt-5.5",
    "MYND_MEMORY_OPENAI_MODEL": "gpt-5-mini",
    "MYND_MEMORY_GEMINI_MODEL": "gemini-3-flash",
    "MYND_MEMORY_NEBIUS_MODEL": "meta-llama/Llama-3.3-70B-Instruct",
    "NEBIUS_EMBED_MODEL": "Qwen/Qwen3-Embedding-8B",
    "MYND_MEMORY_MAX_OUTPUT_TOKENS": "420"
  },
  "observability": {
    "enabled": true
  }
}
