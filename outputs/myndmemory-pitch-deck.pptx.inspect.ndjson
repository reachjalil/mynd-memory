{"kind":"textbox","id":"sh/w3m94fu1","slide":7,"text":"WHY NOW","textPreview":"WHY NOW","textChars":7,"textLines":1,"bbox":[72,132,470,28]}
{"kind":"textbox","id":"sh/loj2t83i","slide":7,"text":"The next agent platform needs memory as a product surface.","textPreview":"The next agent platform needs memory as a product surface.","textChars":58,"textLines":1,"bbox":[72,182,560,198]}
{"kind":"textbox","id":"sh/ex0nuxc3","slide":7,"text":"As agents move from chat windows into applications, memory becomes infrastructure, UX, governance, and differentiation.","textPreview":"As agents move from chat windows into applications, memory becomes infrastructure, UX, governance, and differentiation.","textChars":119,"textLines":1,"bbox":[74,424,510,112]}
{"kind":"textbox","id":"sh/3itgfmlk","slide":7,"text":"MyndMemory pitch deck","textPreview":"MyndMemory pitch deck","textChars":21,"textLines":1,"bbox":[72,672,260,22]}
