{
  "name": "@mynd-memory/hydradb",
  "version": "0.1.0",
  "description": "Cloudflare-safe HydraDB v2 lifecycle, ingestion, query, and prompt-context helpers for MyndMemory.",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "check": "tsc -p tsconfig.json --noEmit",
    "check:fast": "tsc -p tsconfig.json --noEmit",
    "seed": "tsx scripts/seed.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@hydradb/sdk": "catalog:",
    "@mynd-memory/memory-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
